PORT=3000
HOST=0.0.0.0
NODE_ENV=production
TZ=America/Sao_Paulo

IMAGE_NAME=mvp-pushbus
IMAGE_TAG=productionfull

APP_HOST=mvp-pushbus.i9cidade.com.br
TRAEFIK_NETWORK=web
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=lets-encrypt

CITTATI_BASE_URL=https://flits.cittati.com.br
CITTATI_APP_CODE=200
CITTATI_CLIENT_ID=1
CITTATI_COMPANY_ID=seu_company_id

# Preencha localmente. Nao publique seu .env real.
CITTATI_USERNAME=
CITTATI_PASSWORD=

# Opcional: se ja tiver um token manual, o sistema usa como token inicial.
# Mesmo assim, se usuario/senha estiverem preenchidos, ele tenta renovar quando expirar.
CITTATI_TOKEN=
